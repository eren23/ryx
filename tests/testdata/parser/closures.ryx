// Closures — lambda expressions in various forms

fn main() {
    // Simple lambda
    let inc = |x| x + 1;

    // Lambda with type annotations
    let add = |x: Int, y: Int| x + y;

    // Lambda with return type
    let double = |x: Int| -> Int { x * 2 };

    // Zero-param lambda
    let constant = || 42;

    // Zero-param lambda with return type
    let typed_const = || -> Int { 42 };

    // Lambda with block body
    let complex = |x: Int| {
        let y = x * 2;
        y + 1
    };

    // Higher-order: lambda returning lambda
    let adder = |x: Int| -> (Int) -> Int {
        |y: Int| -> Int { x + y }
    };

    // Lambda as function argument
    let result = map(items, |x| x * 2);

    // Lambda with multiple params and block
    let combine = |a: Int, b: Int, c: Int| -> Int {
        let sum = a + b;
        sum + c
    };

    // Immediately invoked lambda
    let val = (|x| x + 1)(41);

    // Lambda in let with complex body
    let processor = |data: [Int]| -> Int {
        let mut total = 0;
        for item in data {
            total = total + item;
        };
        total
    };
}
