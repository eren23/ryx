// Generics — type parameters, bounds, generic usage

// Single generic parameter
fn id<T>(x: T) -> T { x }

// Multiple generic parameters
fn pair<A, B>(a: A, b: B) -> (A, B) { (a, b) }

// Generic with single bound
fn show<T: Display>(x: T) -> String { x.to_string() }

// Generic with multiple bounds
fn print_and_compare<T: Display + Ord>(a: T, b: T) {}

// Generic struct
struct Pair<A, B> {
    first: A,
    second: B,
}

// Generic ADT
type Tree<T> {
    Leaf(T),
    Node(Tree<T>, T, Tree<T>),
}

// Generic trait
trait Container<T> {
    fn get(self) -> T;
    fn set(self, val: T) -> Self;
}

// Generic impl
impl<T> Container<T> for Box<T> {
    fn get(self) -> T { self.value }
    fn set(self, val: T) -> Self { self }
}

// Nested generics
fn nested<T>(x: Vec<Option<T>>) -> Option<Vec<T>> {
    None
}

// Multiple bounds on multiple params
fn complex<T: Show + Clone, U: Hash + Eq>(a: T, b: U) {}

// Generic function type parameter
fn apply<T, U>(f: (T) -> U, x: T) -> U { f(x) }

// Generic with fn keyword type
fn higher<T>(f: fn(T) -> Bool, x: T) -> Bool { f(x) }
