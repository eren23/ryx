// Simple character-by-character number parser

fn char_to_digit(c: Char) -> Int {
    if c == '0' { 0 }
    else if c == '1' { 1 }
    else if c == '2' { 2 }
    else if c == '3' { 3 }
    else if c == '4' { 4 }
    else if c == '5' { 5 }
    else if c == '6' { 6 }
    else if c == '7' { 7 }
    else if c == '8' { 8 }
    else if c == '9' { 9 }
    else { -1 }
}

fn parse_int(s: String, start: Int, len: Int) -> Int {
    let mut result = 0;
    let mut i = start;
    while i < len {
        let d = char_to_digit(s[i]);
        if d == -1 { break };
        result = result * 10 + d;
        i = i + 1;
    };
    result
}

fn main() {
    println(char_to_digit('5'));
    println(parse_int("12345", 0, 5));
    println(parse_int("99", 0, 2));
    println(char_to_digit('x'))
}
