// 3x3 matrix multiplication using flat arrays

fn main() {
    // Matrix A (3x3, row-major):
    // 1 2 3
    // 4 5 6
    // 7 8 9
    let a = [1, 2, 3, 4, 5, 6, 7, 8, 9];

    // Matrix B (3x3, row-major):
    // 9 8 7
    // 6 5 4
    // 3 2 1
    let b = [9, 8, 7, 6, 5, 4, 3, 2, 1];

    // Result C = A * B
    let mut c = [0, 0, 0, 0, 0, 0, 0, 0, 0];
    let n = 3;

    let mut i = 0;
    while i < n {
        let mut j = 0;
        while j < n {
            let mut sum = 0;
            let mut k = 0;
            while k < n {
                sum = sum + a[i * n + k] * b[k * n + j];
                k = k + 1;
            };
            c[i * n + j] = sum;
            j = j + 1;
        };
        i = i + 1;
    };

    // Print result row by row
    let mut idx = 0;
    while idx < 9 {
        println(c[idx]);
        idx = idx + 1;
    }
}
