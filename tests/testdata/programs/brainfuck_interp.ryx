// Simple instruction interpreter
// Opcodes: 1=increment, 2=decrement, 3=move right, 4=move left, 5=print cell

fn main() {
    // Program: increment 3 times, print, move right, increment 5 times, print
    let program = [1, 1, 1, 5, 3, 1, 1, 1, 1, 1, 5];
    let mut tape = [0, 0, 0, 0, 0, 0, 0, 0];
    let mut ptr = 0;
    let mut pc = 0;
    let prog_len = 11;

    while pc < prog_len {
        let instr = program[pc];
        if instr == 1 {
            tape[ptr] = tape[ptr] + 1;
        } else if instr == 2 {
            tape[ptr] = tape[ptr] - 1;
        } else if instr == 3 {
            ptr = ptr + 1;
        } else if instr == 4 {
            ptr = ptr - 1;
        } else if instr == 5 {
            println(tape[ptr]);
        };
        pc = pc + 1;
    }
}
