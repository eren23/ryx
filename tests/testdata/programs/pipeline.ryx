// Pipeline pattern with three stages connected by channels

fn main() {
    let ch1 = channel<Int>(5);
    let ch2 = channel<Int>(5);
    let ch3 = channel<Int>(5);

    // Stage 1: generate numbers 1..5
    spawn {
        let mut i = 1;
        while i <= 5 {
            ch1.send(i);
            i = i + 1;
        };
        ch1.send(-1);
    };

    // Stage 2: double each value
    spawn {
        let mut done = false;
        while !done {
            let val = ch1.recv();
            if val == -1 {
                ch2.send(-1);
                done = true;
            } else {
                ch2.send(val * 2);
            };
        };
    };

    // Stage 3: add 1 to each value
    spawn {
        let mut done = false;
        while !done {
            let val = ch2.recv();
            if val == -1 {
                ch3.send(-1);
                done = true;
            } else {
                ch3.send(val + 1);
            };
        };
    };

    // Collect results and sum
    let mut sum = 0;
    let mut done = false;
    while !done {
        let val = ch3.recv();
        if val == -1 {
            done = true;
        } else {
            sum = sum + val;
        };
    };
    println(sum)
}
