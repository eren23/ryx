fn make_adder(x: Int) -> (Int) -> Int {
    |y: Int| -> Int { x + y }
}

fn apply(f: (Int) -> Int, val: Int) -> Int {
    f(val)
}

fn compose(f: (Int) -> Int, g: (Int) -> Int) -> (Int) -> Int {
    |x: Int| -> Int { f(g(x)) }
}

fn main() {
    let add5 = make_adder(5);
    println(add5(10));
    println(add5(20));

    let double = |x: Int| -> Int { x * 2 };
    println(apply(double, 7));

    let add5_then_double = compose(double, add5);
    println(add5_then_double(3));

    let mut counter = 0;
    let mut i = 0;
    while i < 5 {
        counter = counter + i;
        i = i + 1;
    };
    println(counter)
}
